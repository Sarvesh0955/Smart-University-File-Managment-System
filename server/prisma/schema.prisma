// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  STUDENT
  SENIOR
  ADMIN
}

enum Status {
  ACTIVE
  PENDING
}

enum Category {
  NOTES
  BOOK
  PYQ
  ASSIGNMENT
  LAB
  MISC
}

enum ClassStatus {
  CLASSIFIED
  PENDING
  NEEDS_REVIEW
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  status    Status   @default(ACTIVE)
  year      Int?
  createdAt DateTime @default(now())

  collegeId    String?
  college      College?    @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  semesterId   String?
  semester     Semester?   @relation(fields: [semesterId], references: [id], onDelete: SetNull)

  resources Resource[]
  chatSessions ChatSession[]

  @@map("users")
}

model College {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())

  departments Department[]
  users       User[]
  resources   Resource[]

  @@map("colleges")
}

model Department {
  id        String   @id @default(uuid())
  name      String
  code      String
  createdAt DateTime @default(now())

  collegeId String
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  semesters Semester[]
  subjects  Subject[]
  resources Resource[]
  users     User[]

  @@unique([name, collegeId])
  @@unique([code, collegeId])
  @@map("departments")
}

model Semester {
  id        String   @id @default(uuid())
  number    Int
  createdAt DateTime @default(now())

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  subjects  Subject[]
  resources Resource[]
  users     User[]

  @@unique([number, departmentId])
  @@map("semesters")
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String
  createdAt DateTime @default(now())

  semesterId   String
  semester     Semester   @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  resources Resource[]

  @@map("subjects")
}

model Resource {
  id           String       @id @default(uuid())
  name         String
  mimeType     String
  size         Int
  diskPath     String
  fileHash     String?      @unique
  category     Category?
  classStatus  ClassStatus  @default(CLASSIFIED)
  aiConfidence Int?
  createdAt    DateTime     @default(now())

  subjects     Subject[]
  chunks       DocumentChunk[]
  semesterId   String?
  semester     Semester?    @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  collegeId    String?
  college      College?     @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@map("resources")
}

model DocumentChunk {
  id         String   @id @default(uuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int
  embedding  Unsupported("vector(384)")
  createdAt  DateTime @default(now())

  @@map("document_chunks")
}

model ChatSession {
  id        String   @id @default(uuid())
  title     String   @default("New Chat")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  role      String
  content   String
  sources   Json?
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@map("chat_messages")
}
